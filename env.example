# Database Configuration
DATABASE_URL="postgresql://nyayasetu:password@localhost:5433/nyayasetu_db"
POSTGRES_USER=nyayasetu
POSTGRES_PASSWORD=password
POSTGRES_DB=nyayasetu_db

# JWT Configuration
JWT_SECRET_KEY="your-super-secret-jwt-key-change-this-in-production"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Configuration
API_V1_STR="/api/v1"
PROJECT_NAME="NyayaSetu DBT System"
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Aadhaar API Configuration (Simulated)
AADHAAR_API_URL="https://api.uidai.gov.in/otp"
AADHAAR_API_KEY="your-aadhaar-api-key"

# OTP Configuration
OTP_EXPIRE_MINUTES=5
OTP_LENGTH=6

# DigiLocker Configuration (Simulated)
DIGILOCKER_API_URL="https://api.digilocker.gov.in"
DIGILOCKER_CLIENT_ID="your-digilocker-client-id"
DIGILOCKER_CLIENT_SECRET="your-digilocker-client-secret"

# Gemini AI Configuration
GEMINI_API_KEY="AIzaSyCzxQGmrgHa_v1tFJdfzdth2PCdZALFCfE"
GEMINI_MODEL="gemini-pro"

# File Upload Configuration
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_FILE_TYPES=["pdf", "jpg", "jpeg", "png", "doc", "docx"]


# Email Configuration (for notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM_EMAIL="noreply@nyayasetu.gov.in"

# Push Notification Configuration
FCM_SERVER_KEY="your-fcm-server-key"
FCM_PROJECT_ID="your-fcm-project-id"

# Environment
ENVIRONMENT="development"
DEBUG=true

# Frontend Configuration
NEXT_PUBLIC_API_URL="http://localhost:8000"
NEXT_PUBLIC_APP_NAME="NyayaSetu"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# Security
SECRET_KEY="your-super-secret-key-change-this-in-production"
ALLOWED_HOSTS=["localhost", "127.0.0.1", "0.0.0.0"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=100

